generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COORDENADOR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(COORDENADOR)
  scopeCode    String   @default("default")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DailyRevenue {
  id        String   @id @default(cuid())
  scopeCode String
  product   String
  amount    Float
  date      DateTime
  createdAt DateTime @default(now())

  @@index([scopeCode, product, date])
}
